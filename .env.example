# Copy this file to .env.local and fill in values
# .env.local is gitignored — never commit real secrets

# ─── Google Analytics ──────────────────────────────────────────────────────────
# Get from: analytics.google.com → Admin → Data Streams → Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Google Search Console ─────────────────────────────────────────────────────
# Get from: search.google.com/search-console → Settings → Ownership verification
# → HTML tag method → copy the content value only (not the full tag)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_verification_token_here

# ─── GitHub API (for statistics page contributions heatmap) ────────────────────
# Create at: github.com/settings/tokens → Fine-grained token → read:user scope
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ─── Resend (contact form email delivery) ──────────────────────────────────────
# Without RESEND_API_KEY the /api/contact route returns 503 + { fallback: "mailto" }
# and the client falls back to opening the user's mail client. Set this to
# actually deliver messages. Get one at resend.com/api-keys.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Optional "From" header — defaults to onboarding@resend.dev. Requires a
# verified domain in Resend to use a custom sender.
RESEND_FROM=Shailesh <hello@yourverifieddomain.com>
